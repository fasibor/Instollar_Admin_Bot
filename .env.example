# ─────────────────────────────────────────────
#  INSTOLLAR TELEGRAM BOT — Environment Config
# ─────────────────────────────────────────────

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# The Telegram chat ID of your public community channel/group
COMMUNITY_CHAT_ID=-1001234567890

# The Telegram chat ID of the private admin group (for gig applications)
ADMIN_GROUP_ID=-1009876543210

# Comma-separated list of Telegram user IDs who are admins
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=123456789

# Database file path (SQLite)
DB_PATH=./data/instollar.db

# Time zone for daily summary (e.g. Africa/Lagos)
TZ=Africa/Lagos

# Daily summary cron time (default: 8:00 PM Lagos time)
DAILY_SUMMARY_CRON=0 20 * * *

# Node environment
NODE_ENV=production
