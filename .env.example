# Instollar Bot Environment Configuration
# Copy this file to .env and fill in your values

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# The Telegram chat ID of your public community channel/group
COMMUNITY_CHAT_ID=-1001234567890

# The Telegram chat ID of the private admin group (for gig applications)
ADMIN_GROUP_ID=-1004567891234

# Comma-separated list of Telegram user IDs who are admins
# Get your ID by messaging @userinfobot on Telegram
ADMIN_IDS=123456789,987654321

# PostgreSQL database connection string (Railway provides this)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/instollar

# Time zone for scheduled tasks
TZ=Africa/Lagos

# Weekly summary cron time (default: 8:00 PM every Sunday)
WEEKLY_SUMMARY_CRON=0 20 * * 0

# Monthly summary cron time (default: 8:00 PM on 1st of every month)
MONTHLY_SUMMARY_CRON=0 20 1 * *

# Node environment
NODE_ENV=production
